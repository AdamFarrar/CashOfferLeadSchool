  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @cols/database drizzle-kit generate",
    "db:migrate": "pnpm --filter @cols/database drizzle-kit migrate",
